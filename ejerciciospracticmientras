ejercicio 11 menu con operaciones
LEER num1
LEER num2

contadorOperaciones <- 0
opcion <- 0

MIENTRAS opcion <> 6 HACER
    ESCRIBIR "1 Suma"
    ESCRIBIR "2 Resta"
    ESCRIBIR "3 Multiplicacion"
    ESCRIBIR "4 Division"
    ESCRIBIR "5 Cantidad operaciones"
    ESCRIBIR "6 Salir"

    LEER opcion

    SEGUN opcion HACER
        1:
            ESCRIBIR num1 + num2
            contadorOperaciones <- contadorOperaciones + 1
        2:
            ESCRIBIR num1 - num2
            contadorOperaciones <- contadorOperaciones + 1
        3:
            ESCRIBIR num1 * num2
            contadorOperaciones <- contadorOperaciones + 1
        4:
            SI num2 <> 0 ENTONCES
                ESCRIBIR num1 / num2
                contadorOperaciones <- contadorOperaciones + 1
            FIN SI
        5:
            ESCRIBIR contadorOperaciones
    FIN SEGUN
FIN MIENTRAS
