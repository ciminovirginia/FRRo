mayor y  menor de 5 numeros
// Valida que no sean negativos

contador <- 0

MIENTRAS contador < 5 HACER
    LEER num

    MIENTRAS num < 0 HACER
        ESCRIBIR "Error. Ingrese numero no negativo"
        LEER num
    FIN MIENTRAS

    SI contador = 0 ENTONCES
        mayor <- num
        menor <- num
    SINO
        SI num > mayor ENTONCES
            mayor <- num
        FIN SI

        SI num < menor ENTONCES
            menor <- num
        FIN SI
    FIN SI

    contador <- contador + 1
FIN MIENTRAS

ESCRIBIR "Mayor: ", mayor
ESCRIBIR "Menor: ", menor

Promedio de alumnos
// Promedio por alumno y general

LEER cantAlumnos
LEER cantParciales

sumaGeneral <- 0

PARA i <- 1 HASTA cantAlumnos HACER
    sumaAlumno <- 0

    PARA j <- 1 HASTA cantParciales HACER
        LEER nota

        MIENTRAS nota <= 0 O nota > 10 HACER
            ESCRIBIR "Nota invalida"
            LEER nota
        FIN MIENTRAS

        sumaAlumno <- sumaAlumno + nota
    FIN PARA

    promedioAlumno <- sumaAlumno / cantParciales
    ESCRIBIR "Promedio alumno: ", promedioAlumno

    sumaGeneral <- sumaGeneral + promedioAlumno
FIN PARA

promedioGeneral <- sumaGeneral / cantAlumnos
ESCRIBIR "Promedio general: ", promedioGeneral

